# ----------------------------------------------------------------------------
# Greenfeathers Farm Bakery — environment variables
# Copy this file to .env.local and fill in the values.
# The PUBLIC site works without Supabase (it falls back to the seeded menu),
# but to SAVE changes from /admin you must connect Supabase below.
# ----------------------------------------------------------------------------

# Supabase — find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (SERVER ONLY — never expose to the browser).
# Used by /admin to write menu changes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ----------------------------------------------------------------------------
# Admin login
# ----------------------------------------------------------------------------

# The 6-digit numeric password used to log in at /admin
ADMIN_PASSWORD=123456

# A long random secret used to sign the admin session cookie.
# Generate one with:  openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# ----------------------------------------------------------------------------
# Production
# ----------------------------------------------------------------------------

# Your live site URL (no trailing slash). Used for absolute social/OG image URLs.
# e.g. https://greenfeathersbakery.com  (or your Vercel domain)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
